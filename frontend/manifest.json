{
  "manifest_version": 3,
  "name": "Smart Text Expander",
  "version": "2.0.0",
  "description": "AI-powered snippet manager with cloud sync, smart suggestions, and keyboard shortcuts.",
  "permissions": ["storage", "activeTab", "scripting", "commands", "identity"],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "commands": {
    "insert-snippet": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Open snippet picker on current page"
    },
    "toggle-extension": {
      "suggested_key": { "default": "Ctrl+Shift+E", "mac": "Command+Shift+E" },
      "description": "Enable/disable Smart Text Expander"
    }
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "exclude_matches": ["chrome://*/*", "chrome-extension://*/*"]
    }
  ]
}